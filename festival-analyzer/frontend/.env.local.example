# ─────────────────────────────────────────────────────────────
# Festival Analyzer — frontend environment
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored. NEVER commit real keys.
# ─────────────────────────────────────────────────────────────

# Supabase — public (anon) read access only.
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Apple Music (OPTIONAL).
# Leave blank to ship Spotify-only; the Apple Music toggle will show a
# graceful "not configured" state. To enable, generate a MusicKit
# developer token (ES256 JWT) — see docs/API_REFERENCE.md.
NEXT_PUBLIC_APPLE_MUSIC_DEV_TOKEN=
