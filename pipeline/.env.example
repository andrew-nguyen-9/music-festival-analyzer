# ─────────────────────────────────────────────────────────────
# Soundcheck — pipeline (backend) secrets TEMPLATE.
# Copy to `.env` (gitignored) and fill in. Run scripts from this folder.
# ─────────────────────────────────────────────────────────────

# Supabase (pipeline writes via service-role key — keep secret)
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Spotify — https://developer.spotify.com/dashboard (Client Credentials)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Unsplash — https://unsplash.com/developers
UNSPLASH_APP_ID=
UNSPLASH_ACCESS_KEY=

# Anthropic — https://console.anthropic.com (fun facts generator)
ANTHROPIC_API_KEY=

# Ticketmaster Discovery — https://developer.ticketmaster.com (lineup_scraper + v3.2 aggregator, primary)
TICKETMASTER_API_KEY=

# SeatGeek — https://seatgeek.com/account/develop (v3.2 aggregator cross-validation, optional)
SEATGEEK_CLIENT_ID=

# Setlist.fm — https://api.setlist.fm/docs/1.0/index.html (lineup_scraper historical fallback)
SETLIST_API_KEY=
