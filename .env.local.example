# ─────────────────────────────────────────────────────────────
# Soundcheck — frontend environment
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored. NEVER commit real keys.
#
# The frontend needs these Supabase values (public/anon read).
# Spotify / Unsplash / Anthropic *secret* keys are backend-only → pipeline/.env
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Smart playlists (v2.9) — Spotify PKCE public client. This is the public
# client ID only (no secret; PKCE needs none). Register the redirect URI
# `${origin}/spotify/callback` in your Spotify app. Leave blank to disable the
# "Make my playlist" feature (it degrades to a "not configured" note).
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
