# ─────────────────────────────────────────────────────────────
# Festival Analyzer — frontend environment
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored. NEVER commit real keys.
#
# The frontend needs ONLY these two Supabase values (public/anon read).
# Spotify / Unsplash / Anthropic keys are backend-only → pipeline/.env
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
